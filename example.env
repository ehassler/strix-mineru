# ── MinerU ROCm Configuration ────────────────────────────────────────────────
# This file is read by both docker-compose and make.
# Edit values here — no need to touch docker-compose.yml or Makefile.

# API port
MINERU_PORT=8000

# Host GIDs for GPU device access (find with: stat -c '%g' /dev/kfd /dev/dri/renderD128)
# If both devices share the same GID (common), set only GPU_GID.
# If they differ, set both RENDER_GID and KFD_GID instead.
GPU_GID=991
# RENDER_GID=
# KFD_GID=

# Host directories mounted into the container
MINERU_MODELS=./models
MINERU_OUTPUT=./output

# GPU memory limit for MinerU inference (in GB, blank = auto-detect)
MINERU_VIRTUAL_VRAM_SIZE=

# Fraction of VRAM for KV cache (0.0–1.0, used by vllm engine)
GPU_MEMORY_UTILIZATION=0.9

# Enable experimental memory-efficient attention via AOTriton (0 = off, 1 = on)
TORCH_ROCM_AOTRITON_ENABLE_EXPERIMENTAL=1